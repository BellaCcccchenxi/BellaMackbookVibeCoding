{
  "name": "poetry-widget",
  "productName": "每日诗词",
  "version": "1.0.0",
  "description": "Mac / Windows 桌面每日诗词浮窗 · 农历匹配经典古诗 · 清新古韵国风",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist:mac": "electron-builder --mac",
    "dist:win": "electron-builder --win"
  },
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "dependencies": {
    "lunar-javascript": "^1.7.3"
  },
  "build": {
    "appId": "com.poetry.widget",
    "productName": "每日诗词",
    "artifactName": "PoetryWidget-${version}-${arch}.${ext}",
    "directories": { "output": "release" },
    "files": [
      "main.js",
      "preload.js",
      "renderer.js",
      "almanac.js",
      "poems.js",
      "index.html",
      "styles.css",
      "assets/**/*"
    ],
    "mac": {
      "target": [{ "target": "dmg", "arch": "universal" }],
      "category": "public.app-category.lifestyle",
      "identity": null
    },
    "win": {
      "target": ["nsis"]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "每日诗词"
    }
  }
}
